# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# Generate a new SPAPI_ENCRYPTION_KEY with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Python / BSR ─────────────────────────────────────────────────────────────
BSR_PYTHON_BIN=

# ── Development ───────────────────────────────────────────────────────────────
# Set to "true" to skip auth redirects during UI development only.
# MUST be "false" (or unset) in production.
NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# ── Deployment domain ─────────────────────────────────────────────────────────
# Set to your Vercel URL (or custom domain) after deployment.
# Required for Amazon OAuth domain-guard and the dev-warning banner.
APP_PUBLIC_URL=
NEXT_PUBLIC_APP_URL=

# ── Amazon SP-API ─────────────────────────────────────────────────────────────
# From: Amazon Solution Provider Portal → Your App → App details + LWA credentials
# SERVER-ONLY vars (SPAPI_LWA_CLIENT_SECRET, SPAPI_ENCRYPTION_KEY) must never
# be prefixed with NEXT_PUBLIC_.
SPAPI_APPLICATION_ID=
SPAPI_LWA_CLIENT_ID=
SPAPI_LWA_CLIENT_SECRET=
SPAPI_LOGIN_URI=
SPAPI_REDIRECT_URI=
SPAPI_ENCRYPTION_KEY=

# ── Razorpay (fill when KYC approved) ────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ── Review Request Automation (EasyHOME/India, see REVIEW_REQUEST_AUTOMATION_SPEC.md) ─
# The dry-run catch-up script (scripts/review-requests-catchup.ts) never sends
# a review request regardless of these values -- it has no send code path at
# all. The eligibility-processor route
# (src/app/api/review-requests/jobs/process-eligibility) DOES have a
# live-send code path, but it only runs when BOTH of the next two vars are
# set to the non-default value below -- committed defaults keep it
# dry-run-only. Do not set REVIEW_REQUESTS_ENABLED=true /
# REVIEW_REQUESTS_DRY_RUN=false in production without explicit approval.
REVIEW_REQUESTS_ENABLED=false
REVIEW_REQUESTS_DRY_RUN=true
REVIEW_REQUESTS_MARKETPLACE_ID=A21TJRUUN4KGV
REVIEW_REQUESTS_CATCHUP_DAYS=30
# Eligibility-processor batch cap per invocation (src/app/api/review-requests/
# jobs/process-eligibility). 300 was the pre-2026-07-17-split default and is
# no longer safe: 300 * REVIEW_REQUESTS_RATE_LIMIT_MS (1100ms) alone is 330s,
# already past Vercel's 280s function ceiling before any API/DB overhead.
# 120 keeps mandatory throttling (~132s) comfortably inside the 220s
# internal runtime budget (REVIEW_REQUESTS_RUNTIME_BUDGET_MS below).
REVIEW_REQUESTS_BATCH_SIZE=120
REVIEW_REQUESTS_RATE_LIMIT_MS=1100
# Rolling overlap window (days) for the daily order-ingestion fetch -- wide
# enough that a single failed/delayed cron cycle never misses an order.
REVIEW_REQUESTS_OVERLAP_DAYS=3
# Internal graceful-stop budget (ms) for the eligibility processor -- it
# stops claiming new candidates once this elapses and returns a partial-run
# summary, rather than depending on Vercel's 280s platform timeout to kill
# the function mid-batch (see the 2026-07-17 production finding).
REVIEW_REQUESTS_RUNTIME_BUDGET_MS=220000
# How long (minutes) a claimed-but-never-finalized 'checking' row must sit
# before the next eligibility-processor run reclaims it back to 'pending'.
# Recovers rows orphaned by a runtime-budget stop or a hard platform kill.
REVIEW_REQUESTS_STALE_CLAIM_TTL_MINUTES=15
