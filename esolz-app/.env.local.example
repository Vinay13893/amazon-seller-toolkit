# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Supabase ────────────────────────────────────────────────────────────────
# Find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-key>

# Service-role key — server-side only, NEVER prefix with NEXT_PUBLIC_
# Used by API route handlers to bypass RLS for trusted server writes.
# Find it in: Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-secret-key>

# ── App ─────────────────────────────────────────────────────────────────────
# Backend API URL (FastAPI / Python backend)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Development ──────────────────────────────────────────────────────────────
# Set to "true" to skip auth redirects during UI development.
# REMOVE or set to "false" before production deployment.
NEXT_PUBLIC_DEV_AUTH_BYPASS=true

# ── Python Integration ───────────────────────────────────────────────────────
# Python binary for BSR scraper (optional — falls back to python3)
# Example: C:\Python314\python.exe  or  /usr/bin/python3
BSR_PYTHON_BIN=

# Python binary for Pincode checker (optional — uses BSR_PYTHON_BIN if not set)
# Example: C:\Python314\python.exe  or  /usr/bin/python3
PINCODE_PYTHON_BIN=
