# =============================================================
# Amazon Ads Automation Tool - Environment Configuration
# =============================================================
# Copy this file to .env and fill in your credentials.
#
# For multi-client setup, duplicate each block with a prefix:
#   AMZN_ADS_CLIENTNAME_CLIENT_ID=...
#   AMZN_ADS_CLIENTNAME_REFRESH_TOKEN=...
# And set: AMZN_ADS_CLIENTS=default,clientname
# =============================================================

# ── Default Client Credentials ──────────────────────────────
AMZN_ADS_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxx
AMZN_ADS_CLIENT_SECRET=your_client_secret_here
AMZN_ADS_REFRESH_TOKEN=Atzr|your_refresh_token_here

# ── API Settings ────────────────────────────────────────────
# Region: na (US/CA/MX/BR), eu (IN/UK/DE/FR/IT/ES), fe (JP/AU)
AMZN_ADS_REGION=eu
AMZN_ADS_MARKETPLACE=IN

# Profile ID (get this by running: python -m amazon_ads_tool profiles)
AMZN_ADS_PROFILE_ID=

# ── Optimization Settings ───────────────────────────────────
AMZN_ADS_TARGET_ACOS=25.0
AMZN_ADS_MAX_BID=50.0
AMZN_ADS_MIN_BID=1.0

# ── Multi-Client Example ────────────────────────────────────
# AMZN_ADS_CLIENTS=default,storexyz,brandabc
#
# AMZN_ADS_STOREXYZ_CLIENT_ID=amzn1.application-oa2-client.yyyyyyyy
# AMZN_ADS_STOREXYZ_CLIENT_SECRET=secret_for_storexyz
# AMZN_ADS_STOREXYZ_REFRESH_TOKEN=Atzr|token_for_storexyz
# AMZN_ADS_STOREXYZ_REGION=eu
# AMZN_ADS_STOREXYZ_MARKETPLACE=IN
# AMZN_ADS_STOREXYZ_PROFILE_ID=1234567890
# AMZN_ADS_STOREXYZ_TARGET_ACOS=20.0
