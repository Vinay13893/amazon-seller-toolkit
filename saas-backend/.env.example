# ─────────────────────────────────────────────────────────────
# e-Solz Amazon Tools — Environment Variables
# Copy this to .env and fill in all values before running
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# App
APP_NAME="e-Solz Amazon Tools"
DEBUG=false

# Generate with: python -c "from jose import jwt; import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-jwt-key-min-32-chars

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-base64-key-here

# ─── Database (Supabase) ──────────────────────────────────────
# Supabase > Settings > Database > Connection string (URI mode)
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# ─── Redis (Upstash) ─────────────────────────────────────────
# Upstash > Redis > Connect > Python > URL
REDIS_URL=rediss://default:password@xxx.upstash.io:6379

# ─── AWS S3 (for Excel/PDF report storage) ───────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=esolz-reports
AWS_REGION=ap-south-1

# ─── Email (Resend.com) ───────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@e-solz.com

# ─── Amazon SP-API (your developer app — shared across all users) ─
# From Seller Central > Apps & Services > Develop Apps
SP_API_LWA_APP_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SP_API_LWA_CLIENT_SECRET=amzn1.oa2-cs.v1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS IAM keys used for SigV4 signing of SP-API requests
SP_API_AWS_ACCESS_KEY=AKIA...
SP_API_AWS_SECRET_KEY=...

# ─── Amazon Ads API (your developer app) ─────────────────────
ADS_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADS_CLIENT_SECRET=amzn1.oa2-cs.v1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Razorpay (payments — add when ready for billing) ────────
# RAZORPAY_KEY_ID=rzp_live_xxx
# RAZORPAY_KEY_SECRET=xxx
